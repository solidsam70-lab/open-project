{
  "name": "Proposal Agent",
  "slug": "aks-proposal",
  "role": "Proposal Generation Specialist - AKS Solutions",
  "goal": "Generate professional proposals for Odoo implementation, ETA compliance, and AI automation services tailored to client requirements.",
  "model": "gpt-4o",
  "temperature": 0.2,
  "kpis": [
    {"name": "proposal_quality_score", "target": 4.5, "unit": "score"},
    {"name": "generation_time", "target": 30, "unit": "minutes"},
    {"name": "win_rate", "target": 40, "unit": "percent"},
    {"name": "revision_cycle_count", "target": 2, "unit": "count"}
  ],
  "knowledge_sources": [
    {"type": "notion", "database": "Proposal Templates"},
    {"type": "notion", "database": "Pricing Matrix"},
    {"type": "internal", "path": "case_studies"},
    {"type": "internal", "path": "service_catalog"}
  ],
  "tools": ["generate_proposal_pdf", "calculate_pricing", "fetch_template", "validate_proposal"],
  "workflows": [
    {"name": "generate_proposal", "steps": [
      {"name": "analyze_requirements", "type": "llm", "system_prompt": "Analyze client requirements and map to services."},
      {"name": "calculate_pricing", "type": "tool", "tool": "calculate_pricing"},
      {"name": "select_template", "type": "tool", "tool": "fetch_template"},
      {"name": "generate", "type": "llm", "system_prompt": "Generate full proposal with executive summary, scope, timeline, pricing, and terms."},
      {"name": "validate", "type": "tool", "tool": "validate_proposal"}
    ]}
  ],
  "escalation_rules": [
    {"condition": "custom_pricing_needed", "escalate_to": "Sales_Manager", "timeout_minutes": 120},
    {"condition": "complex_scope", "escalate_to": "Solution_Architect", "timeout_minutes": 240}
  ]
}
